{
    "name": "veriablesign/datatable",
    "description": "A simple datatable package for Laravel",
    "keywords": [
        "veriablesign",
        "datatable"
    ],
    "homepage": "https://github.com/veriablesign/datatable",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Variable Sign",
            "email": "variablesign@gmail.com",
            "homepage": "https://variablesign.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.2",
        "illuminate/support": ">=7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0",
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Veriablesign\\Datatable\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Veriablesign\\Datatable\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"

    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Veriablesign\\Datatable\\DatatableServiceProvider"
            ],
            "aliases": {
                "Datatable": "Veriablesign\\Datatable\\Facades\\Datatable"
            }
        }
    }
}
